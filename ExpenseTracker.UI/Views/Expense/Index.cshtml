@model List<ExpenseTracker.UI.Models.ExpenseViewModel>

@{
    ViewBag.Title = "Expenses";
}

<div style="padding:20px; background:#f5f7fb; border-radius:12px;">

    <h2 style="margin-bottom:15px;">Expenses</h2>

    <!-- ADD BUTTON -->
    <div style="margin-bottom:15px;">
        <a href="/Expense/Create"
           style="padding:8px 15px; background:#5b8cff; color:white; border-radius:6px; text-decoration:none;">
            + Add Expense
        </a>
    </div>

    <!-- FILTER -->
    <form method="get" style="margin-bottom:15px;">
        <select name="category" onchange="this.form.submit()" class="form-control" style="width:220px;">
            <option value="">All Categories</option>

            @foreach (var c in ViewBag.FilterCategories)
            {
                <option value="@c" @(Request["category"] == c ? "selected" : "")>
                    @c
                </option>
            }
        </select>
    </form>

    <!-- TABLE -->
    <table style="width:100%; border-collapse:collapse; background:white; border-radius:10px; overflow:hidden;">
        <thead style="background:#2c3e50; color:white;">
            <tr>
                <th style="padding:12px;">Category</th>
                <th style="padding:12px;">Amount</th>
                <th style="padding:12px;">Date</th>
                <th style="padding:12px;">Notes</th>
                <th style="padding:12px;">Actions</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr style="border-bottom:1px solid #eee;">
                        <td style="padding:10px;">
                            <span style="font-size:18px;">@item.Icon</span>
                            <span style="color:@item.Color; font-weight:600;">
                                @item.CategoryName
                            </span>
                        </td>

                        <td style="padding:10px; font-weight:500;">
                            ₹ @item.Amount
                        </td>

                        <td style="padding:10px;">
                            @item.ExpenseDate.ToString("dd-MM-yyyy")
                        </td>

                        <td style="padding:10px;">
                            @item.Notes
                        </td>

                        <td style="padding:10px;">
                            <a href="/Expense/Edit/@item.Id"
                               style="padding:5px 10px; background:#ffc107; color:black; border-radius:5px; text-decoration:none;">
                                Edit
                            </a>

                            <a href="#"
                               onclick="confirmDelete(@item.Id)"
                               style="padding:5px 10px; background:#dc3545; color:white; border-radius:5px; text-decoration:none;">
                                Delete
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" style="padding:15px; text-align:center;">
                        No data available
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>

<!-- 🔥 DELETE MODAL -->
<div id="deleteModal" style="
display:none;
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,0.5);
justify-content:center;
align-items:center;
z-index:9999;">

    <div style="background:white; padding:20px; border-radius:10px; width:320px; text-align:center;">
        <h5 style="margin-bottom:10px;">Confirm Delete</h5>
        <p style="margin-bottom:20px;">Are you sure you want to delete this expense?</p>

        <button onclick="proceedDelete()" class="btn btn-danger">Yes</button>
        <button onclick="closeModal()" class="btn btn-secondary">Cancel</button>
    </div>
</div>

<script>
    let deleteId = 0;

    function confirmDelete(id) {
        deleteId = id;
        document.getElementById("deleteModal").style.display = "flex";
    }

    function closeModal() {
        document.getElementById("deleteModal").style.display = "none";
    }

    function proceedDelete() {
        window.location.href = "/Expense/Delete/" + deleteId;
    }
</script>